# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Trading mode: true = paper trading (sin dinero real), false = live
PAPER_MODE=true

# Capital inicial para el portfolio de paper trading
PAPER_INITIAL_CAPITAL=10000.0

# Slippage simulado en paper trading (0.001 = 0.1%)
PAPER_SLIPPAGE=0.001

# Telegram notifications
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# v0.5 safety guards
STOP_LOSS_PCT=0.05               # fallback fixed % stop (used only when ATR unavailable)
STOP_LOSS_ATR_MULTIPLIER=2.0     # ATR-based stop: entry_price - 2 * ATR(14); wider for volatile stocks
EARNINGS_BLACKOUT_DAYS=3
REGIME_FILTER_ENABLED=true

# Trade Republic (only needed in live mode, iteration 2)
# TR_PHONE=+34600000000
# TR_PIN=1234
